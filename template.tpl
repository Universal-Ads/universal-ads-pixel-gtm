___TESTS___

scenarios:
- name: Test 1 — Full flow — SDK loads, patcher runs, events sent
  code: |-
    var injectUrls = [];
    var callPaths = [];
    var callArgs = [];

    mock('makeString', function(v) { return (v === undefined || v === null) ? '' : ('' + v); });
    mock('getType', function(v) { return (v && typeof v === 'object') ? 'object' : typeof v; });
    mock('logToConsole', function() {});

    var patchedState = false;
    mock('copyFromWindow', function(key) {
      if (key === 'pubSuite.startWithConfig') return undefined;
      if (key === 'pubSuite.sendConversion') return undefined;
      if (key === '__uapx_started_v3') return false;
      if (key === '__uapx_patched_v3') return patchedState;
      return undefined;
    });

    mock('injectScript', function(url, onSuccess, onFailure, cacheKey) {
      injectUrls.push(url);
      if (url.indexOf('uap-gtm-patch.js') > -1) patchedState = true;
      onSuccess();
    });

    mock('callInWindow', function(path, a, b) {
      callPaths.push(path);
      callArgs.push(a);
    });

    mock('setInWindow', function(key, val) {
      if (key === '__uapx_patched_v3') patchedState = val;
    });

    runCode({
      productId: 'aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa',
      accessToken: 'TOKEN123',
      eventType: 'purchase',
      fireAutoPageViewOnInit: false,
      eventParamsTable: [{ keyType: 'price', value: '129.99' }],
      gtmOnSuccess: function() {},
      gtmOnFailure: function() {}
    });

    assertThat(injectUrls.length).isEqualTo(2);
    assertThat(injectUrls[0].indexOf('uap.js')).isGreaterThan(-1);
    assertThat(injectUrls[1].indexOf('uap-gtm-patch.js')).isGreaterThan(-1);
    assertThat(callPaths.indexOf('pubSuite.startWithConfig') > -1).isTrue();
    assertThat(callPaths.indexOf('pubSuite.sendConversion') > -1).isTrue();
    assertThat(callArgs.indexOf('purchase') > -1).isTrue();
