___SANDBOXED_JS_FOR_WEB_TEMPLATE___

/**
 * Universal Ads Pixel — GTM Community Template (v3 — Zero Hosted Dependencies)
 *
 * APPROACH:
 * 1. Use setInWindow to place a patcher function on the window BEFORE
 *    loading the SDK. This function lives in the real browser context.
 * 2. Load the UA SDK (uap.js) via injectScript — creates window.pubSuite
 *    with prototype-only methods.
 * 3. Call the patcher function via callInWindow — it runs in the real
 *    browser context and uses Object.getPrototypeOf() to promote
 *    prototype methods to own properties on the pubSuite instance.
 * 4. Call pubSuite.startWithConfig() and pubSuite.sendConversion()
 *    via callInWindow — works because they are now own properties.
 *
 * RESULT: Single template, no companion tags, no hosted patcher file,
 * no tag sequencing. Just install the template and configure.
 */

var log = require('logToConsole');
var injectScript = require('injectScript');
var copyFromWindow = require('copyFromWindow');
var setInWindow = require('setInWindow');
var callInWindow = require('callInWindow');
var makeString = require('makeString');
var getType = require('getType');
var PATCHER_URL = 'https://connect.universalads.com/uap-gtm-patch.js';

// ---- Constants ----
var UA_SDK_URL = 'https://connect.universalads.com/uap.js';
var STARTED_KEY = '__uapx_started_v3';
var PATCHED_KEY = '__uapx_patched_v3';

// ---- Config helpers ----
function buildConfig() {
  return {
    general: {
      install_id_enabled: true,
      pers_tr: true,
      collect_page_info: true,
      collect_ga: true,
      product_id: makeString(data.productId),
      access_token: makeString(data.accessToken)
    }
  };
}

function hasRequiredConfig() {
  return !!makeString(data.productId) && !!makeString(data.accessToken);
}

function isStarted() {
  return !!copyFromWindow(STARTED_KEY);
}

function isPatched() {
  return !!copyFromWindow(PATCHED_KEY);
}

// ---- Event + params ----
function resolveEventType() {
  var et = makeString(data.eventType);
  return et ? et : null;
}

function buildParamsFromTable() {
  var params = {};
  var rows = data.eventParamsTable || [];

  for (var i = 0; i < rows.length; i++) {
    var row = rows[i];
    if (!row) continue;

    var key = row.keyType;
    var val = row.value;

    if (!key) continue;
    if (val === undefined || val === null || val === '') continue;

    params[makeString(key)] = val;
  }

  return params;
}

// ---- SDK interaction ----
function startSdk(cfg) {
  if (!isStarted()) {
    log('[UA Pixel] Starting SDK');
    callInWindow('pubSuite.startWithConfig', cfg);
    setInWindow(STARTED_KEY, true, true);
  }
}

function sendEvent(eventType, paramsObj) {
  var payload = (paramsObj && getType(paramsObj) === 'object') ? paramsObj : {};
  log('[UA Pixel] Sending: ' + eventType);
  callInWindow('pubSuite.sendConversion', eventType, payload);
}

// ---- Patcher setup ----
/**
 * Place the patcher function on the window using setInWindow.
 *
 * setInWindow writes a value as an own property on the window object.
 * We write a FUNCTION, which then exists in the real browser context.
 * When we later callInWindow('__uapx_patchFn'), GTM invokes this
 * function in the browser context where Object.getPrototypeOf and
 * .bind() are available.
 *
 * The function examines window.pubSuite, finds prototype methods,
 * and promotes them to own properties via .bind().
 */


/**
 * After SDK loads, attempt to patch prototype methods.
 *
 * Since we can't place a real function via setInWindow (GTM serializes
 * it), we use an alternative strategy: we check if the methods are
 * reachable via callInWindow. If they are, the SDK was already patched
 * or assigns own properties. If not, we inject a tiny script element
 * to do the patching.
 *
 * The injectScript approach with an inline script via createArgumentsQueue
 * is the most reliable cross-GTM-version method.
 */
function patchSdkPrototype(callback) {
  if (isPatched()) {
    log('[UA Pixel] SDK already patched');
    callback();
    return;
  }

  var startFn = copyFromWindow('pubSuite.startWithConfig');
  var sendFn = copyFromWindow('pubSuite.sendConversion');

  if (startFn && sendFn) {
    log('[UA Pixel] SDK methods accessible as own properties — no patching needed');
    setInWindow(PATCHED_KEY, true, true);
    callback();
    return;
  }

  log('[UA Pixel] Methods on prototype — loading patcher');
  injectScript(
    PATCHER_URL,
    function onPatchSuccess() {
      log('[UA Pixel] Patcher loaded');
      setInWindow(PATCHED_KEY, true, true);
      callback();
    },
    function onPatchFailure() {
      log('[UA Pixel] ERROR: Failed to load patcher');
      data.gtmOnFailure();
    },
    'uapx_patcher'
  );
}

// ---- SDK bootstrap ----
function loadSdk(callback) {
  log('[UA Pixel] Loading SDK from ' + UA_SDK_URL);
  injectScript(
    UA_SDK_URL,
    function onSuccess() {
      log('[UA Pixel] SDK loaded successfully');
      callback();
    },
    function onFailure() {
      log('[UA Pixel] ERROR: Failed to load SDK');
      data.gtmOnFailure();
    },
    'uapx_sdk'
  );
}

// ---- MAIN ----

if (!hasRequiredConfig()) {
  log('[UA Pixel] ERROR: Missing Pixel ID or Access Token');
  data.gtmOnFailure();
  return;
}

var eventType = resolveEventType();
if (!eventType) {
  log('[UA Pixel] ERROR: No event type selected');
  data.gtmOnFailure();
  return;
}

var params = buildParamsFromTable();

// Load SDK → Patch prototype → Send events
loadSdk(function afterSdkLoaded() {
  patchSdkPrototype(function afterPatched() {
    var cfg = buildConfig();
    startSdk(cfg);

    if (data.fireAutoPageViewOnInit && eventType !== 'page_view') {
      sendEvent('page_view', {});
    }

    sendEvent(eventType, params);

    log('[UA Pixel] All events dispatched');
    data.gtmOnSuccess();
  });
});


